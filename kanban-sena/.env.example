APP_NAME="Kanban SENA"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# SQLite (desarrollo rápido)
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# MySQL / MariaDB (XAMpp, phpMyAdmin). Si usas MySQL, comenta las 3 líneas de SQLite
# y descomenta/adapta estas:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=kanban_sena
# DB_USERNAME=root
# DB_PASSWORD=
# DB_CHARSET=utf8mb4
# DB_COLLATION=utf8mb4_unicode_ci

BROADCAST_CONNECTION=null

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Copie los mismos valores que REVERB_* para tiempo real en el navegador (Vite).
VITE_REVERB_APP_KEY=
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=8080
VITE_REVERB_SCHEME=http

SESSION_DRIVER=file
SESSION_LIFETIME=120

QUEUE_CONNECTION=sync

MAIL_MAILER=log
